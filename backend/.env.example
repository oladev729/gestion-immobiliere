# Configuration de la base de données
DATABASE_URL=postgresql://username:password@localhost:5432/immobilier_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=immobilier_db
DB_USER=username
DB_PASSWORD=password

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Configuration CaurisPay
CAURISPAY_BASE_URL=http://liveapi.caurispay.com:10110/v1
CAURISPAY_API_KEY=your_caurispay_api_key_here
CAURISPAY_CLIENT_ID=your_caurispay_client_id_here
CAURISPAY_SERVICE_KEY=your_caurispay_service_key_here
CAURISPAY_SERVICE_ID=your_caurispay_service_id_here

# Configuration pour le développement (optionnel)
# Pour utiliser l'API de test CaurisPay, décommentez la ligne suivante :
# CAURISPAY_BASE_URL=http://testapi.caurispay.com:10110/v1

# Configuration upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Configuration email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
